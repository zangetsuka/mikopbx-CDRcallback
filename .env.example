# ===== MikoPBX REST API =====
MIKO_API_URL=https://your-mikopbx-host
MIKO_API_KEY=your_api_key_here
MIKO_VERIFY_SSL=false
MIKO_REQUEST_TIMEOUT=30

# ===== Web server =====
MIKO_WEB_HOST=0.0.0.0
MIKO_WEB_PORT=5000
MIKO_WEB_DEBUG=false

# ===== Storage / logging =====
MIKO_DB_PATH=data/mikoapi.db
MIKO_LOG_FILE=logs/mikoapi.log
MIKO_LOG_LEVEL=INFO
FLASK_SECRET_KEY=change-me

# ===== CDR collector (detect missed calls) =====
MIKO_COLLECTOR_ENABLED=true
MIKO_COLLECT_INTERVAL=30
MIKO_COLLECT_LIMIT=50

# ===== Callback behaviour =====
CALLBACK_ENABLED=true
CALLBACK_AUTO_CREATE=true
CALLBACK_DELAY_MINUTES=2
CALLBACK_MAX_DELAY=5
CALLBACK_NOTIFICATION_AUDIO=callback-notification
CALLBACK_NOTIFICATION_RETRIES=3
CALLBACK_MIN_OPERATORS=1
CALLBACK_MAX_WAIT_TIME=300
CALLBACK_SCHEDULER_INTERVAL=10
CALLBACK_RETRY_DELAY_SECONDS=120
CALLBACK_MAX_RETRIES=3
CALLBACK_DRY_RUN=false

# ===== AMI (Asterisk Manager Interface) =====
# AMI must be enabled in MikoPBX; the user needs the "originate" privilege
# and the service host must be allowed in manager.conf.
AMI_HOST=10.0.0.1
AMI_PORT=5038
AMI_USERNAME=callback_daemon
AMI_PASSWORD=change-me

# ===== Routing / dialplan =====
# Destination queue number (the answered client is bridged here in queue mode).
CALLBACK_QUEUE=2200101
# Operator extension used in "direct" routing mode.
CALLBACK_OPERATOR_EXTENSION=302
# Context where the queue / operator lives (the originate DESTINATION context).
# On a default MikoPBX this is usually "internal".
CALLBACK_CONTEXT=internal
# Context used for ringing into the queue (legacy / optional).
CALLBACK_QUEUE_CONTEXT=internal
CALLBACK_ORIGINATE_TIMEOUT=60
CALLBACK_OPERATOR_RING_SECONDS=2

# NOTE on the client channel:
# The number of the CLIENT is dialled through the OUTBOUND context, configured
# in the UI as "client_channel_template", e.g.  Local/{phone}@outgoing
# (on MikoPBX external numbers are matched there and routed to the SIP trunk).
# Verify your own context names with:  asterisk -rx "dialplan show <exten>@<context>"

# ===== Client-number filtering (anti-junk callbacks) =====
# Comma-separated list of YOUR OWN external numbers (DIDs). The service will
# never call these back even if they appear as a caller.
CALLBACK_OWN_DIDS=74812283016
# Regex a CALLER number must match to be eligible for a callback.
# Default = Russian format: 7 or 8 followed by 10 digits (11 total).
# This automatically excludes internal extensions (302) and feature codes (777, 900).
CALLBACK_CLIENT_NUMBER_REGEX=[78]\d{10}
# Do not call back missed calls older than this many minutes. Prevents the
# service from dialing the entire CDR history on first start. 0 = disabled.
CALLBACK_MAX_CALL_AGE_MINUTES=60

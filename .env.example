# MikoPBX API Configuration

MIKO_API_URL=[https://your-pbx-ip](https://your-pbx-ip)
MIKO_API_KEY=your-api-key-here
MIKO_VERIFY_SSL=false

# Collection Settings

MIKO_COLLECT_INTERVAL=30
MIKO_CALLS_LIMIT=100

# Web Server

WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# Database

DB_PATH=data/calls.db

# Logging

LOG_LEVEL=INFO
LOG_FILE=logs/app.log